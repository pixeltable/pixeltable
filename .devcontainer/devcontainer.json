{
  "name": "pixeltable-cockroach",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "remoteUser": "ubuntu",
  "workspaceFolder": "/workspaces/pixeltable",
  "shutdownAction": "stopCompose",
  "forwardPorts": [22089, 26257, 8080],
  "portsAttributes": {
    "22089": {
      "label": "Pixeltable Dashboard",
      "onAutoForward": "openBrowser"
    },
    "26257": {
      "label": "CockroachDB SQL",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "CockroachDB Admin UI",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "anthropic.claude-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/miniforge/envs/pxt/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
